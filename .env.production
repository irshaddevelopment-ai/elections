# =====================================================================
# PRODUCTION .env for DigitalOcean droplet
# Copy this to /var/www/elections/.env on the server, then:
#   php artisan key:generate --force
#   php artisan config:cache
#   php artisan route:cache
#   php artisan view:cache
# =====================================================================

# --- App ---
APP_NAME="Elections"
APP_ENV=production
APP_KEY=                                # run: php artisan key:generate --force
APP_DEBUG=false                         # MUST be false in production
APP_TIMEZONE=Asia/Beirut                # change to your timezone
APP_URL=https://elections.yourdomain.com

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --- Logging ---
LOG_CHANNEL=daily                       # daily rotation instead of one huge file
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                       # warning in prod; switch to debug only when troubleshooting

# --- Database (MySQL on localhost) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=election
DB_USERNAME=elections_app               # NOT root — see MySQL setup below
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Sessions: Redis (NOT database) ---
SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true              # cookies only over HTTPS
SESSION_SAME_SITE=lax

# --- Cache: Redis ---
CACHE_STORE=redis
CACHE_PREFIX=elections

# --- Queue: keep on DB unless you add a worker ---
QUEUE_CONNECTION=database

# --- Broadcast / Filesystem / Mail ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Redis ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# --- Octane / RoadRunner ---
OCTANE_SERVER=roadrunner
OCTANE_HTTPS=true

# --- App-specific (read directly in loginController) ---
APP_DEFAULTUSER="CHANGE_ME"
SUPERADMIN_USER="CHANGE_ME"
SUPERADMIN_PASS="CHANGE_ME_STRONG_PASSWORD"

VITE_APP_NAME="${APP_NAME}"
