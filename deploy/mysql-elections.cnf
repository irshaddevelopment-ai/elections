# =====================================================================
# MySQL tuning for the elections app
# Drop this on the droplet at: /etc/mysql/mysql.conf.d/elections.cnf
# Then: sudo systemctl restart mysql
#
# Assumes: 16 GB RAM droplet, MySQL co-located with the app.
# If you split MySQL onto its own box, raise innodb_buffer_pool_size
# to ~70% of that box's RAM.
# =====================================================================

[mysqld]

# --- Connections ---
# 16 RoadRunner workers + admin tools + headroom
max_connections          = 200
max_user_connections     = 180
wait_timeout             = 600
interactive_timeout      = 600

# --- InnoDB (the engine all your tables use) ---
# 4 GB buffer pool on a 16 GB droplet leaves plenty for OS + PHP workers
innodb_buffer_pool_size  = 4G
innodb_buffer_pool_instances = 4
innodb_log_file_size     = 512M
innodb_flush_log_at_trx_commit = 1
innodb_flush_method      = O_DIRECT
innodb_file_per_table    = 1

# --- Concurrency / locks ---
# Voting writes use LOCK TABLES; keep this generous so lock waits don't time out
innodb_lock_wait_timeout = 30
table_open_cache         = 4000
table_definition_cache   = 2000
open_files_limit         = 65535

# --- Query / connection buffers ---
max_allowed_packet       = 64M
sort_buffer_size         = 2M
join_buffer_size         = 2M
tmp_table_size           = 64M
max_heap_table_size      = 64M

# --- Char set (matches your dumps: utf8mb3 + utf8mb4) ---
character-set-server     = utf8mb4
collation-server         = utf8mb4_unicode_ci

# --- SQL mode ---
# Your controllers run `SET sql_mode=''` per-request, but set a sane default
# so admin/CLI sessions aren't surprised.
sql_mode = "NO_ENGINE_SUBSTITUTION"

# --- Slow query log (turn on during the voting event to catch issues) ---
slow_query_log           = 1
slow_query_log_file      = /var/log/mysql/slow.log
long_query_time          = 1
log_queries_not_using_indexes = 0
